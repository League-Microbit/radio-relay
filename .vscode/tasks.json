{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "npm run build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$tsc"
        },
        {
            "label": "Deploy",
            "type": "shell",
            "command": "npm run deploy",
            "group": "build",
            "problemMatcher": "$tsc"
        },
        {
            "label": "Test",
            "type": "shell",
            "command": "npm run test",
            "group": "test",
            "problemMatcher": "$tsc"
        }
    ]
}
